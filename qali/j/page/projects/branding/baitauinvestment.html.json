e\u0437\u044f\u0439\u0441\u0442\u0432\u043e.\n\u0423\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u044c: \u0442\u0432\u043e\u0440\u0447\u0435\u0441\u043a\u0438\u0439 \u043f\u043e\u0434\u0445\u043e\u0434, \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u044b\u0435 \u0440\u0435\u0448\u0435\u043d\u0438\u044f.\n\u0426\u0435\u043b\u0435\u0432\u0430\u044f \u0430\u0443\u0434\u0438\u0442\u043e\u0440\u0438\u044f: 25-40, 40 \u0438 \u0432\u044b\u0448\u0435.\n","description2":"\u041a\u043e\u043d\u043a\u0443\u0440\u0435\u043d\u0442\u044b: AHR Kazakhstan, KZ Strata, KazPIR, Light House.\n\u0426\u0432\u0435\u0442\u043e\u0432\u043e\u0435 \u0440\u0435\u0448\u0435\u043d\u0438\u0435: \u0437\u0435\u043b\u0435\u043d\u044b\u0439, \u0431\u0435\u043b\u044b\u0439, \u0433\u043e\u043b\u0443\u0431\u043e\u0439, \u0437\u043e\u043b\u043e\u0442\u043e.\n\u041c\u044b\u0441\u043b\u044c \u0434\u043b\u044f \u043f\u043e\u0442\u0440\u0435\u0431\u0438\u0442\u0435\u043b\u044f: \u0421 \u043d\u0430\u043c\u0438 - \u043f\u0440\u043e\u0446\u0432\u0435\u0442\u0430\u043d\u0438\u0435, \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435, \u0443\u0441\u043f\u0435\u0448\u043d\u043e\u0435 \u0431\u0443\u0434\u0443\u0449\u0435\u0435.","image":"","image2":""},{"type":"\u0418\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0438 \u0442\u0435\u043a\u0441\u0442","title":"\u041e\u0431\u0440\u0430\u0437\u044b","description1":"\u041f\u0435\u0440\u0435\u0447\u0435\u043d\u044c \u0432\u0441\u0435\u0445 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u044b\u0445 \u043e\u0431\u0440\u0430\u0437\u043e\u0432, \u043d\u0430\u043f\u0440\u044f\u043c\u0443\u044e \u0438\u043b\u0438 \u043a\u043e\u0441\u0432\u0435\u043d\u043d\u043e \u0441\u0432\u044f\u0437\u0430\u043d\u043d\u044b\u0445 \u0441\u043e \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435\u043c \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043e \u043b\u043e\u0433\u043e\u0442\u0438\u043f\u0430: \u0433\u043e\u0440\u0430 (\u0441\u0438\u043b\u0430, \u0432\u0435\u043b\u0438\u0447\u0438\u0435, \u043c\u043e\u0449\u044c, \u0441\u0442\u0430\u0431\u0438\u043b\u044c\u043d\u043e\u0441\u0442\u044c, \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435, \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u044c, \u043c\u0430\u0441\u0448\u0442\u0430\u0431\u043d\u043e\u0441\u0442\u044c, \u0438\u0437\u043e\u0431\u0438\u043b\u0438\u0435, \u0433\u043b\u0430\u0432\u0435\u043d\u0441\u0442\u0432\u043e\u0432\u0430\u043d\u0438\u0435, \u0443\u0432\u0435\u0440\u0435\u043d\u043d\u043e\u0441\u0442\u044c), \u0437\u0432\u0435\u0437\u0434\u0430 (\u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435, \u043e\u0431\u044a\u0435\u0434\u0438\u043d\u0435\u043d\u0438\u0435), \u0432\u043e\u0434\u0430 (\u0438\u0437\u043e\u0431\u0438\u043b\u0438\u0435, \u0441\u043f\u043e\u043a\u043e\u0439\u0441\u0442\u0432\u0438\u0435), \u0434\u0435\u0440\u0435\u0432\u043e (\u0441\u0432\u0435\u0436\u0435\u0441\u0442\u044c, \u0434\u043e\u043b\u0433\u043e\u043b\u0435\u0442\u0438\u0435, \u0437\u043d\u0430\u043d\u0438\u044f), \u0440\u0430\u0441\u0441\u0432\u0435\u0442 (\u043d\u0430\u0447\u0430\u043b\u043e, \u044d\u043d\u0435\u0440\u0433\u0438\u044f), \u0441\u043b\u0438\u0442\u043a\u0438 \u0437\u043e\u043b\u043e\u0442\u0430 (\u0438\u0437\u043e\u0431\u0438\u043b\u0438\u0435), \u043a\u043e\u043c\u043f\u0430\u0441 (\u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435), \u043a\u043e\u0440\u043e\u043d\u0430 (\u0443\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435), \u043c\u043e\u043d\u0435\u0442\u044b (\u0431\u043e\u0433\u0430\u0442\u0441\u0442\u0432\u043e), \u043a\u0440\u044b\u043b\u044c\u044f (\u043f\u043e\u043b\u0435\u0442, \u0441\u0432\u043e\u0431\u043e\u0434\u0430), \u043f\u0442\u0438\u0446\u0430 (\u043f\u043e\u043b\u0435\u0442, \u0438\u0437\u044f\u0449\u0435\u0441\u0442\u0432\u043e), \u0442\u0440\u0435\u0443\u0433\u043e\u043b\u044c\u043d\u0438\u043a (\u0441\u0442\u0430\u0431\u0438\u043b\u044c\u043d\u043e\u0441\u0442\u044c, \u0433\u043e\u0440\u0430).","description2":"","image":"assets\/img\/project\/baitau\/baitau1.jpg","image2":""},{"type":"\u0414\u0432\u043e\u0439\u043d\u043e\u0439 \u0442\u0435\u043a\u0441","title":"\u0410\u0441\u0441\u043e\u0446\u0438\u0430\u0446\u0438\u0438","description1":"\u0417\u0430\u0434\u0430\u0447\u0430 \u0431\u0440\u044d\u043d\u0434\u0438\u043d\u0433\u0430 - \u0441\u043e\u0437\u0434\u0430\u0442\u044c \u043f\u0440\u0438\u0432\u043b\u0435\u043a\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u043e\u0431\u0440\u0430\u0437, \u043a\u043e\u0442\u043e\u0440\u044b\u0439, \u0432 \u0434\u0430\u043d\u043d\u043e\u043c \u0441\u043b\u0443\u0447\u0430\u0435, \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u043e\u0432\u0430\u043b \u0431\u044b \u0433\u043b\u0430\u0432\u043d\u043e\u043c\u0443 \u043f\u0443\u043d\u043a\u0442\u0443  - \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0435 \u043e\u0431\u0449\u0435\u0433\u043e \u043b\u043e\u0433\u043e\u0442\u0438\u043f\u0430, \u043d\u0435 \u043f\u0440\u0438\u0432\u044f\u0437\u0430\u043d\u043d\u043e\u0433\u043e \u043a \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u043d\u043e\u0439 \u0441\u0444\u0435\u0440\u0435 \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438. ","description2":"\u0421\u043e\u0447\u0435\u0442\u0430\u043d\u0438\u0435 \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u043e\u043d\u043d\u043e\u0441\u0442\u0438, \u043a\u0440\u0435\u0430\u0442\u0438\u0432\u0430, \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u043e\u0433\u043e \u0442\u0435\u0447\u0435\u043d\u0438\u044f - \u043e\u0441\u043d\u043e\u0432\u0430, \u0437\u0430\u043b\u043e\u0436\u0435\u043d\u043d\u0430\u044f \u0432 \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u0430\u043d\u043d\u044b\u0439 \u043b\u043e\u0433\u043e\u0442\u0438\u043f. \u0410\u0441\u0441\u043e\u0446\u0438\u0430\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u044c \u0437\u0430\u043b\u043e\u0436\u0435\u043d\u043d\u043e\u0433\u043e \u043e\u0431\u0440\u0430\u0437\u0430 \u0437\u0430\u043a\u043b\u044e