430\u043d\u043d\u0430\u044f \u043a\u0430\u0437\u0430\u0445\u0441\u043a\u0438\u043c \u043e\u0440\u043d\u0430\u043c\u0435\u043d\u0442\u043e\u043c.","description2":"","image":"assets\/img\/project\/baitau\/baitau2.jpg","image2":""},{"type":"3 \u0438\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0438","title":"\u0412\u044b\u0431\u0440\u0430\u043d\u043d\u044b\u0435 \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u044b","description1":"","description2":"","image":"assets\/img\/project\/baitau\/baitau2\/baitau5.jpg","image2":"","images":["assets\/img\/project\/baitau\/baitau2\/baitau5.jpg","assets\/img\/project\/baitau\/baitau2\/baitau6.jpg","assets\/img\/project\/baitau\/baitau2\/baitau13.jpg"]},{"type":"\u0414\u0432\u043e\u0439\u043d\u043e\u0439 \u0442\u0435\u043a\u0441","title":"\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u0444\u0438\u043d\u0430\u043b\u0430","description1":"\u041f\u043e\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u043e\u043c \u0443\u0434\u0430\u0447\u043d\u043e\u0439 \u0440\u0430\u0431\u043e\u0442\u0430 \u043c\u0430\u0440\u043a\u0435\u0442\u0438\u043d\u0433\u0430 \u0438 \u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0434\u0438\u0437\u0430\u0439\u043d\u0430, \u0431\u044b\u043b \u0441\u043e\u0437\u0434\u0430\u043d \u0443\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u044b\u0439, \u0432 \u0441\u0432\u043e\u0435\u0439 \u0441\u0444\u0435\u0440\u0435, \u0434\u0438\u0437\u0430\u0439\u043d-\u043f\u0440\u043e\u0435\u043a\u0442. \u041f\u0440\u0438 \u044d\u0442\u043e\u043c \u0441\u043e\u0431\u043b\u044e\u0434\u0435\u043d\u044b \u0432\u0441\u0435 \u043f\u043e\u0436\u0435\u043b\u0430\u043d\u0438\u044f \u0437\u0430\u043a\u0430\u0437\u0447\u0438\u043a\u0430, \u043d\u0430 \u043e\u0441\u043d\u043e\u0432\u0435 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0437\u0430\u0434\u0430\u043d\u0438\u044f.","description2":"","image":"","image2":""},{"type":"\u0418\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0438 \u0442\u0435\u043a\u0441\u0442","title":"\u041f\u043e\u0434\u0431\u043e\u0440 \u0446\u0432\u0435\u0442\u0430","description1":"\u041d\u0430 \u043e\u0441\u043d\u043e\u0432\u0435 \u0442\u0435\u0445\u043d\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0437\u0430\u0434\u0430\u043d\u0438\u044f \u0438 \u043a\u043e\u043d\u043a\u0443\u0440\u0435\u043d\u0442\u043d\u043e\u0433\u043e \u0430\u043d\u0430\u043b\u0438\u0437\u0430, \u0431\u044b\u043b\u0438 \u0432\u044b\u044f\u0432\u043b\u0435\u043d\u044b \u0446\u0432\u0435\u0442\u0430, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u044e\u0442\u0441\u044f \u0432 \u043d\u0430\u0438\u043c\u0435\u043d\u044c\u0448\u0435\u043c \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u0435. \u0422\u0430\u043a \u0436\u0435, \u0443\u0447\u0442\u0435\u043d\u044b \u043f\u043e\u0436\u0435\u043b\u0430\u043d\u0438\u044f \u0437\u0430\u043a\u0430\u0437\u0447\u0438\u043a\u0430 \u043f\u043e \u043f\u0440\u0438\u043e\u0440\u0438\u0442\u0435\u0442\u043d\u043e\u043c\u0443 \u0446\u0432\u0435\u0442\u043e\u0432\u043e\u043c\u0443 \u0440\u0435\u0448\u0435\u043d\u0438\u044e. \u041f\u0440\u0438 \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u0438\u0438 \u0446\u0432\u0435\u0442\u043e\u0432\u043e\u0439 \u0433\u0430\u043c\u043c\u044b \u0443\u0447\u0438\u0442\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u043f\u0441\u0438\u0445\u043e\u043b\u043e\u0433\u0438\u044f \u0446\u0432\u0435\u0442\u0430, \u0442\u0430\u043a, \u0441\u0438\u043d\u0438\u0439 - \u044d\u0442\u043e \u0446\u0432\u0435\u0442 \u0441\u0442\u0430\u0431\u0438\u043b\u044c\u043d\u043e\u0441\u0442\u0438, \u0434\u0443\u0445\u043e\u0432\u043d\u043e\u0441\u0442\u0438, \u043c\u0443\u0434\u0440\u043e\u0441\u0442\u0438, \u0437\u0435\u043b\u0435\u043d\u044b\u0439 - \u0443\u0441\u0442\u043e\u0439\u0447\u0438\u0432\u043e\u0441\u0442\u044c, \u0443\u043f\u043e\u0440\u0441\u0442\u0432\u043e, \u0431\u043b\u0430\u0433\u043e\u0440\u043e\u0434\u0441\u0442\u0432\u043e, \u0431\u0438\u0440\u044e\u0437\u043e\u0432\u044b\u0439 - \u0441\u0442\u0440\u0435\u043c\u043b\u0435\u043d\u0438\u0435, \u0443\u043c\u0438\u0440\u043e\u0442\u0432\u043e\u0440\u0435\u043d\u043d\u043e\u0441\u0442\u044c.","description2":"","image":"assets\/img\/project\/baitau\/baitau4.jpg","image2":""},{"type":"4 \u0438\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0438","title":"\u0418\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435 \u043c\u043e\u043a\u0430\u043f\u043e\u0432","description1":"","description2":"","image":"assets\/img\/project\/baitau\/baitau3\/baitau9.jpg","image2":"","images":["assets\/img\/project\/baitau\/baitau3\/baitau9.jpg","assets\/img\/project\/baitau\/baitau3\/baitau10.jpg","assets\/img\/project\/baitau\/baitau3\/baitau11.jpg","assets\/img\/project\/baitau\/baitau3\/baitau12.jpg"]},{"type":"\u0414\u0432\u043e\u0439\u043d\u043e\u0439 \u0442\u0435\u043a\u0441","title":"\u041e\u0442\u0437\u044b\u0432\u044b","description1":"\"\u0411\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u0438\u043c \u0437\u0430 \u0442\u0449\u0430\u0442\u0435\u043b\u044c\u043d\u0443\u044e \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0443 \u043b\u043e\u0433\u043e\u0442\u0438\u043f\u0430, \u0443\u0447\u0438\u0442\u044b\u0432\u0430\u044f \u043e\u0441\u043e\u0431\u0435\u043d\u043d\u043e\u0441\u0442\u0438 \u0441\u0444\u0435\u0440 \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438 \u0445\u043e\u043b\u0434\u0438\u043d\u0433\u0430. \u0416\u0435\u043b\u0430\u0435\u043c \u043a\u043e\u043c\u0430\u043d\u0434\u0435 \u0434\u0430\u043b\u044c\u043d\u0435\u0439\u0448\u0438\u0445 \u0443\u0441\u043f\u0435\u0445\u043e\u0432, \u043d\u043e\u0432\u044b\u0445 \u0442\u0432\u043e\u0440\u0447\u0435\u0441\u043a\u0438\u0445 \u043f\u043e\u0431\u0435\u0434, \u043a\u0440\u0443\u043f\u043d\u044b\u0445 \u043f\u0440\u043e\u0435\u043a\u0442\u043e\u0432 \u0438 \u043f\u043e\u0441\u0442\u043e\u044f\u043d\u043d\u043e\u0433\u043e \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044f!\"","description2":"","image":"","image2":""}]}