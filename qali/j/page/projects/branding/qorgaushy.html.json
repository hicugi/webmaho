9 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438.\n\u041a\u043e\u043d\u043a\u0443\u0440\u0435\u043d\u0442\u044b: AHR \u041a\u0430\u0437\u0430\u0445\u0441\u0442\u0430\u043d, Strata, KazPIR, Light House.","description2":"\u0426\u0435\u043b\u0435\u0432\u0430\u044f \u0430\u0443\u0434\u0438\u0442\u043e\u0440\u0438\u044f: \u0441\u0440\u0435\u0434\u043d\u0438\u0439 \u0438 \u043a\u0440\u0443\u043f\u043d\u044b\u0439 \u0431\u0438\u0437\u043d\u0435\u0441.\n\u041f\u0440\u0438\u043e\u0440\u0438\u0442\u0435\u0442\u044b \u0432 \u043e\u0431\u0440\u0430\u0437\u0430\u0445: \u0449\u0438\u0442, \u043a\u0440\u0435\u043f\u043e\u0441\u0442\u044c, \u0437\u0430\u0449\u0438\u0442\u0430, \u0441\u0438\u0441\u0442\u0435\u043c\u0430.\n\u041f\u043e\u0441\u044b\u043b \u043f\u043e\u0442\u0440\u0435\u0431\u0438\u0442\u0435\u043b\u044e: \u0412\u044b \u043f\u043e\u0434 \u0437\u0430\u0449\u0438\u0442\u043e\u0439.","image":"","image2":""},{"type":"\u0418\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0438 \u0442\u0435\u043a\u0441\u0442","title":"\u041e\u0431\u0440\u0430\u0437\u044b","description1":"\u041f\u0435\u0440\u0435\u0447\u0435\u043d\u044c \u0432\u0441\u0435\u0445 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u044b\u0445 \u043e\u0431\u0440\u0430\u0437\u043e\u0432, \u043d\u0430\u043f\u0440\u044f\u043c\u0443\u044e \u0438\u043b\u0438 \u043a\u043e\u0441\u0432\u0435\u043d\u043d\u043e \u0441\u0432\u044f\u0437\u0430\u043d\u043d\u044b\u0445 \u0441\u043e \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435\u043c \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043e \u043b\u043e\u0433\u043e\u0442\u0438\u043f\u0430: \u043a\u0440\u0435\u043f\u043e\u0441\u0442\u044c, \u0449\u0438\u0442, \u043a\u0430\u0440\u0430\u0443\u043b, \u0437\u0430\u0441\u0442\u0430\u0432\u0430, \u043f\u0430\u043d\u0446\u044b\u0440\u044c, \u043c\u0435\u0447, \u0448\u043b\u0435\u043c, \u0433\u0440\u0430\u043d\u0438\u0446\u0430, \u0441\u0438\u0441\u0442\u0435\u043c\u0430, \u0441\u0442\u0435\u043d\u0430, \u0441\