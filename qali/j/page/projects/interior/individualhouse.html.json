\u0430\u0439-\u0442\u0435\u043a.","description2":"\u041e\u0434\u043d\u0438\u043c \u0438\u0437 \u043e\u0441\u043d\u043e\u0432\u043d\u044b\u0445 \u043f\u043e\u0436\u0435\u043b\u0430\u043d\u0438\u0439 \u0437\u0430\u043a\u0430\u0437\u0447\u0438\u043a\u0430 \u0431\u044b\u043b\u043e \u043e\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435 \u0434\u0435\u0440\u0435\u0432\u0430 \u0432 \u0437\u0430\u043a\u043b\u0430\u0434\u044b\u0432\u0430\u0435\u043c\u044b\u0445 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u0430\u0445. \u0411\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u044f \u043a\u043e\u043d\u0446\u0435\u043f\u0446\u0438\u0438 \u0441\u0442\u0438\u043b\u044f \u0434\u0430\u043d\u043d\u043e\u0435 \u043f\u043e\u0436\u0435\u043b\u0430\u043d\u0438\u0435 \u043f\u043e\u043b\u0443\u0447\u0438\u043b\u043e\u0441\u044c \u0432\u044b\u043f\u043e\u043b\u043d\u0438\u0442\u044c \u0432 \u043f\u043e\u043b\u043d\u043e\u043c \u043e\u0431\u044a\u0435\u043c\u0435.","image":"","image2":""},{"type":"\u0422\u0435\u043a\u0441\u0442 \u0438 \u0438\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435","title":"\u041f\u043b\u0430\u043d\u0438\u0440\u043e\u0432\u043a\u0430","description1":"\u041f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u043e \u0434\u043e\u043c\u0430 \u0440\u0430\u0441\u043f\u043e\u043b\u0430\u0433\u0430\u0435\u0442\u0441\u044f \u043d\u0430 \u0434\u0432\u0443\u0445 \u044d\u0442\u0430\u0436\u0430\u0445, \u0432 \u0445\u043e\u0434\u0435 \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u043a\u0438 \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0435\u0439 \u043f\u043b\u0430\u043d\u0438\u0440\u043e\u0432\u043a\u0438 \u0431\u044b\u043b\u043e \u0440\u0435\u0448\u0435\u043d\u043e \u0440\u0430\u0437\u043c\u0435\u0441\u0442\u0438\u0442\u044c \u043d\u0430 \u043f\u0435\u0440\u0432\u043e\u043c \u044d\u0442\u0430\u0436\u0435 \u043e\u0442\u0434\u0435\u043b\u0435\u043d\u043d\u0443\u044e \u0437\u043e\u043d\u0443 \u043e\u0442\u0434\u044b\u0445\u0430, \u0441\u043e\u0432\u043c\u0435\u0449\u0435\u043d\u043d\u0443\u044e \u0433\u043e\u0441\u0442\u0438\u043d\u0443\u044e \u0438 \u0441\u0442\u043e\u043b\u043e\u0432\u0443\u044e, \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u0443\u044e \u043a\u0443\u0445\u043d\u044e \u0438 \u0440\u0430\u0431\u043e\u0447\u0438\u0439 \u043a\u0430\u0431\u0438\u043d\u0435\u0442. \u041d\u0430 \u0432\u0442\u043e\u0440\u043e\u043c \u044d\u0442\u0430\u0436\u0435 \u0440\u0430\u0441\u043f\u043e\u043b\u043e\u0436\u0438\u043b\u0438\u0441\u044c \u043f\u0440\u0438\u0432\u0430\u0442\u043d\u044b\u0435 \u0430\u043f\u0430\u0440\u0442\u0430\u043c\u0435\u043d\u0442\u044b - \u0445\u043e\u0437\u044f\u0439\u0441\u043a\u0430\u044f \u0441\u043f\u0430\u043b\u044c\u043d\u044f, \u0434\u0435\u0442\u0441\u043a\u0438\u0435 \u043a\u043e\u043c\u043d\u0430\u0442\u044b, \u0433\u0430\u0440\u0434\u0435\u0440\u043e\u0431.","description2":"","image":"assets\/img\/project\/taras\/taras17.jpg","image2":""},{"type":"\u0418\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0438 \u0442\u0435\u043a\u0441\u0442","title":"\u041a\u043e\u043b\u043b\u0430\u0436","description1":"\u041d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u0445\u0430\u0439-\u0442\u0435\u043a \u043f\u0440\u043e\u043f\u0438\u0442\u0430\u043d\u043e \u0432\u0435\u044f\u043d\u0438\u044f\u043c\u0438 \u0432\u044b\u0441\u043e\u043a\u0438\u0445 \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0439. \u0412 \u043f\u0435\u0440\u0432\u0443\u044e \u043e\u0447\u0435\u0440\u0435\u0434\u044c, \u0438\u043d\u0442\u0435\u0440\u044c\u0435\u0440 \u0432 \u0441\u0442\u0438\u043b\u0435 \u0445\u0430\u0439-\u0442\u0435\u043a - \u044d\u0442\u043e \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u044c, \u0443\u0440\u043e\u0432\u0435\u043d\u044c, \u043f\u0440\u0435\u0441\u0442\u0438\u0436 \u0438 \u0432\u044b\u0441\u043e\u043a\u0430\u044f \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0447\u043d\u043e\u0441\u0442\u044c. \u0414\u0438\u0437\u0430\u0439\u043d-\u043f\u0440\u043e\u0435\u043a\u0442 \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d \u0432 \u0445\u043e\u043b\u043e\u0434\u043d\u044b\u0445 \u0441\u0432\u0435\u0442\u043b\u043e-\u0441\u0435\u0440\u044b\u0445, \u0431\u0435\u043b\u044b\u0445 \u0438 \u0447\u0435\u0440\u043d\u044b\u0445 \u043e\u0442\u0442\u0435\u043d\u043a\u0430\u0445. \u0428\u0438\u0440\u043e\u043a\u043e \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u043e \u043f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u0435 \u043c\u0435\u0442\u0430\u043b\u043b\u0430, \u0441\u0442\u0435\u043a\u043b\u0430, \u043a\u0430\u043c\u043d\u044f \u0438 \u043f\u043b\u0430\u0441\u0442\u0438\u043a\u0430. \u0410\u043a\u0446\u0435\u043d\u0442 \u0441\u0434\u0435\u043b\u0430\u043d \u043d\u0430 \u043a\u0440\u0430\u0441\u043e\u0447\u043d\u044b\u0445 \u0430\u043a\u0441\u0435\u0441\u0441\u0443\u0430\u0440\u0430\u0445 \u0438  \u0434\u0435\u043a\u043e\u0440\u0430\u0442\u0438\u0432\u043d\u044b\u0445 \u0434\u043e\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u044f\u0445.","description2":"","image":"assets\/img\/project\/taras\/13taras.jpg","image2":""},{"type":"\u0414\u0432\u043e\u0439\u043d\u043e\u0439 \u0442\u0435\u043a\u0441","title":"\u041a\u043e\u043d\u0446\u0435\u043f\u0442","description1":"\u0414\u0438\u0437\u0430\u0439\u043d\u0435\u0440\u0441\u043a\u043e\u0435 \u0440\u0435\u0448\u0435\u043d\u0438\u0435, \u043f\u043e\u0434\u0445\u043e\u0434\u044f\u0449\u0435\u0435 \u0434\u043b\u044f \u0436\u0438\u043b\u043e\u0433\u043e \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u0430, \u0431\u044b\u043b\u043e \u0437\u0430\u043a\u043b\u044e\u0447\u0435\u043d\u043e \u0432 \u0440\u0430\u0437\u0431\u0430\u0432\u043b\u0435\u043d\u0438\u0438 \u0441\u0442\u0438\u043b\u044f \u0445\u0430\u0439-\u0442\u0435\u043a \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u043c. \u0422\u0430\u043a, \u043f\u0440\u0438\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u044f\u0441\u044c \u043e\u0441\u043e\u0431\u0435\u043d\u043d\u043e\u0441\u0442\u044f\u043c \u0445\u0430\u0439-\u0442\u0435\u043a\u0430, \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u043e \u0432\u043c\u0435\u0449\u0430\u043b\u043e \u043c\u0438\u043d\u0438\u043c\u0443\u043c \u0434\u0435\u043a\u043e\u0440\u0430, \u0430 \u043e\u0441\u043d\u043e\u0432\u043d\u043e\u0435 \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u0435 \u043f\u0440\u0438\u043a\u043e\u0432\u044b\u0432\u0430\u043b\u043e \u0433\u043e\u0441\u043f\u043e\u0434\u0441\u0442\u0432\u043e \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438, \u0432\u0438\u0437\u0443\u0430\u043b\u044c\u043d\u043e\u0435 \u043f\u0440\u0438\u0442\u044f\u0436\u0435\u043d\u0438\u0435 \u043a \u0444\u043e\u0440\u043c\u0435 \u0438 \u0444\u0430\u043a\u0442\u0443\u0440\u0435 \u0434\u0435\u0442\u0430\u043b\u0435\u0439. \u041f\u043e\u0434\u0431\u043e\u0440 \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u043d\u043e\u0439 \u043c\u0435\u0431\u0435\u043b\u0438 \u0431\u044b\u043b \u0430\u043a\u0446\u0435\u043d\u0442\u0438\u0440\u043e\u0432\u0430\u043d \u043d\u0430 \u0441\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0439 \u0441\u0442\u0438\u043b\u044c, \u0434\u043b\u044f \u0443\u0434\u043e\u0431\u0441\u0442\u0432\u0430 \u043f\u0440\u043e\u0436\u0438\u0432\u0430\u044e\u0449\u0438\u0445.","description2":"\u0412 \u0438\u0441\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u0438 \u0446\u0432\u0435\u0442\u043e\u0432\u043e\u0433\u043e \u0440\u0435\u0448\u0435\u043d\u0438\u044f \u0434\u043e\u043c\u0438\u043d\u0438\u0440\u0443\u0435\u0442 \u0431\u0435\u043b\u044b\u0439 \u0446\u0432\u0435\u0442, \u0440\u0430\u0437\u0431\u0430\u0432\u043b\u044f\u044f \u0435\u0433\u043e \u043d\u0435\u0439\u0442\u0440\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u0447\u0435\u0440\u043d\u044b\u043c \u0446\u0432\u0435\u0442\u043e\u043c \u0438 \u043e\u0442\u0442\u0435\u043d\u043a\u0430\u043c\u0438 \u0441\u0435\u0440\u043e\u0433\u043e. \u041e\u0431\u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u043e \u043f\u043e\u0442\u043e\u043b\u043a\u043e\u0432 \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u043e \u0432 \u0441\u0442\u0440\u043e\u0433\u043e\u0439 \u0433\u0435\u043e\u043c\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \u0444\u043e\u0440\u043c\u044b, \u0431\u0435\u0437 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u044f \u043c\u0430\u0441\u0441\u0438\u0432\u043d\u044b\u0445 \u0441\u0432\u0435\u0442\u043e\u043e\u0441\u0432\u0435\u0442\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0445 \u043f\u0440\u0438\u0431\u043e\u0440\u043e\u0432, \u043e\u0441\u0442\u0430\u0432\u043b\u044f\u044f \u0433\u043b\u0430\u0432\u0435\u043d\u0441\u0442\u0432\u0443\u044e\u0449\u0438\u043c - \u0432\u0441\u0442\u0440\u043e\u0435\u043d\u043d\u043e\u0435 \u043e\u0441\u0432\u0435\u0449\u0435\u043d\u0438\u0435. \u0428\u0438\u0440\u043e\u043a\u043e \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u044e\u0442\u0441\u044f \u0437\u0435\u0440\u043a\u0430\u043b\u0430 \u0438 \u0441\u0442\u0435\u043a\u043b\u044f\u043d\u043d\u044b\u0435 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u044b, \u0442\u0435\u043c \u0441\u0430\u043c\u044b\u043c \u0432\u0438\u0437\u0443\u0430\u043b\u044c\u043d\u043e \u0443\u0432\u0435\u043b\u0438\u0447\u0438\u0432\u0430\u044f \u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0441\u0442\u0432\u043e.","image":"","image2":""},{"type":"\u0422\u0435\u043a\u0441\u0442 \u0438 \u0438\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435","title":"\u041a\u043e\u043c\u043f\u043b\u0435\u043a\u0442\u0430\u0446\u0438\u044f","description1":"\u041e\u0441\u043d\u043e\u0432\u043e\u0439 \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u0434\u0438\u0437\u0430\u0439\u043d-\u043f\u0440\u043e\u0435\u043a\u0442\u0430 \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0440\u0435\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f, \u043f\u043e\u044d\u0442\u043e\u043c\u0443 \u0434\