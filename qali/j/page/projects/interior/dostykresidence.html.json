3c \u043d\u0430 12 \u043f\u0435\u0440\u0441\u043e\u043d, \u0441 \u0432\u0438\u0442\u0440\u0438\u043d\u0430\u043c\u0438 \u043f\u043e\u0434 \u043f\u043e\u0441\u0443\u0434\u0443 \u0438 \u0438\u0437\u044f\u0449\u043d\u044b\u043c \u0434\u0438\u0432\u0430\u043d\u043e\u043c, \u0433\u043e\u0441\u0442\u0438\u043d\u0430\u044f, \u043f\u0440\u0435\u0434\u043f\u043e\u043b\u0430\u0433\u0430\u0435\u043c\u0430\u044f, \u043a\u0430\u043a \u0437\u043e\u043d\u0430 \u043e\u0442\u0434\u044b\u0445\u0430 \u0441 \u043a\u043e\u043c\u0444\u043e\u0440\u0442\u043d\u043e\u0439 \u043c\u044f\u0433\u043a\u043e\u0439 \u043c\u0435\u0431\u0435\u043b\u044c\u044e, \u043a\u0430\u043c\u0438\u043d\u043e\u043c \u0438 \u043a\u043d\u0438\u0436\u043d\u044b\u043c\u0438 \u043f\u043e\u043b\u043a\u0430\u043c\u0438. \u0412\u0442\u043e\u0440\u043e\u0439 \u044d\u0442\u0430\u0436 \u0437\u043d\u0430\u0447\u0438\u0442\u0441\u044f, \u043a\u0430\u043a \u043f\u0440\u0438\u0432\u0430\u0442\u043d\u0430\u044f \u0437\u043e\u043d\u0430 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u044b, \u0440\u0430\u0437\u0434\u0435\u043b\u0435\u043d \u043d\u0430 \u0440\u043e\u0434\u0438\u0442\u0435\u043b\u044c\u0441\u043a\u0443\u044e \u0438 \u0434\u0435\u0442\u0441\u043a\u0438\u0435 \u043a\u043e\u043c\u043d\u0430\u0442\u044b, \u0442\u0430\u043a \u0436\u0435 \u0438\u0437 \u0432\u0441\u0435\u0445 \u0441\u043f\u0430\u043b\u0435\u043d \u043e\u0431\u043e\u0440\u0443\u0434\u043e\u0432\u0430\u043d \u0432\u044b\u0445\u043e\u0434 \u043d\u0430 \u0442\u0435\u0440\u0440\u0430\u0441\u0443.","description2":"","image":"assets\/img\/project\/dostyk\/gulnur1.jpg","image2":""},{"type":"\u0418\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0438 \u0442\u0435\u043a\u0441\u0442","title":"\u041a\u043e\u043b\u043b\u0430\u0436","description1":"\u0412 \u043f\u0440\u043e\u0435\u043a\u0442\u0435 \u0432\u043e\u043f\u043b\u043e\u0449\u0435\u043d\u043e \u0433\u043b\u0430\u0432\u043d\u043e\u0435 \u043f\u043e\u0436\u0435\u043b\u0430\u043d\u0438\u0435 - \u0441\u043e\u0437\u0434\u0430\u0442\u044c \u0431\u043e\u0433\u0430\u0442\u044b\u0439 \u0438 \u0440\u043e\u0441\u043a\u043e\u0448\u043d\u044b\u0439 \u0438\u043d\u0442\u0435\u0440\u044c\u0435\u0440, \u043d\u0435 \u043f\u0435\u0440\u0435\u0433\u0440\u0443\u0436\u0435\u043d\u043d\u044b\u0439 \u043b\u0438\u0448\u043d\u0438\u043c\u0438 \u0434\u0435\u043a\u043e\u0440\u0430\u0442\u0438\u0432\u043d\u044b\u043c\u0438 \u044d\u043b\u0435\u043c\u0435\u043d\u0442\u0430\u043c\u0438, \u0441\u043e\u0437\u0434\u0430\u0432\u0430\u044f \u0441\u0434\u0435\u0440\u0436\u0430\u043d\u043d\u044b\u0439 \u0438 \u044d\u043b\u0435\u0433\u0430\u043d\u0442\u043d\u044b\u0439 \u043e\u0431\u0440\u0430\u0437. \u041a\u0430\u0436\u0434\u0430\u044f \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u0430\u044f \u0436\u0438\u043b\u0430\u044f \u0437\u043e\u043d\u0430 \u0432\u043a\u043b\u044e\u0447\u0430\u0435\u0442 \u0432 \u0441\u0435\u0431\u044f \u0432\u0441\u0435 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u044b\u0439 \u043d\u0430\u0431\u043e\u0440 \u0434\u043b\u044f \u0436\u0438\u0437\u043d\u0438 \u0432 \u043f\u043e\u043c\u0435\u0449\u0435\u043d\u0438\u0438 \u0438 \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u0430 \u0432 \u043e\u0434\u043d\u043e\u043c \u0441\u0442\u0438\u043b\u0435.","description2":"","image":"assets\/img\/project\/dostyk\/collagedostyk.jpg","image2":""},{"type":"\u0414\u0432\u043e\u0439\u043d\u043e\u0439 \u0442\u0435\u043a\u0441","title":"\u041a\u043e\u043d\u0446\u0435\u043f\u0442","description1":"\u041f\u043e\u043b \u0432\u044b\u0441\u0442\u043b\u0430\u043d \u0431\u0435\u043b\u044b\u043c \u043b\u0430\u043c\u0438\u043d\u0430\u0442\u043e\u043c, \u0432 \u0431\u0435\u043b\u043e\u0439 \u044d\u043c\u0430\u043b\u0438 \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u044b \u0442\u0430\u043a\u0436\u0435 \u0434\u0432\u0435\u0440\u0438 \u0438 \u0434\u0432\u0435\u0440\u043d\u044b\u0435 \u043f\u043e\u0440\u0442\u0430\u043b\u044b. \u0426\u0432\u0435\u0442\u043e\u0432\u043e\u0435 \u0440\u0430\u0437\u