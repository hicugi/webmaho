e\u0439, \u0430 \u043c\u0435\u0441\u0442\u043e \u0443 \u043e\u043a\u043d\u0430 \u043e\u0442\u0432\u0435\u0434\u0435\u043d\u043e \u043f\u043e\u0434 \u043c\u0430\u0441\u0442\u0435\u0440\u0441\u043a\u0443\u044e \u0434\u043b\u044f \u0437\u0430\u043a\u0430\u0437\u0447\u0438\u0446\u044b-\u0445\u0443\u0434\u043e\u0436\u043d\u0438\u0446\u044b.","description2":"","image":"assets\/img\/project\/irina\/izumrud1.jpg","image2":""},{"type":"\u0418\u0437\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0438 \u0442\u0435\u043a\u0441\u0442","title":"\u041a\u043e\u043b\u043b\u0430\u0436","description1":"\u0418\u043d\u0442\u0435\u0440\u044c\u0435\u0440 \u0432\u044b\u0434\u0435\u0440\u0436\u0430\u043d \u0432 \u0441\u043f\u043e\u043a\u043e\u0439\u043d\u044b\u0445 \u0431\u0435\u0436\u0435\u0432\u043e-\u043a\u043e\u0440\u0438\u0447\u043d\u0435\u0432\u044b\u0445 \u0442\u043e\u043d\u0430\u0445, \u0433\u0430\u0440\u043c\u043e\u043d\u0438\u0447\u043d\u043e \u0441\u043e\u0447\u0435\u0442\u0430\u044e\u0449\u0438\u0439\u0441\u044f \u0441 \u043f\u0440\u0435\u0434\u043c\u0435\u0442\u0430\u043c\u0438 \u043c\u0435\u0431\u0435\u043b\u0438 \u0438 \u0430\u043a\u0441\u0435\u0441\u0441\u0443\u0430\u0440\u043e\u0432 \u0432 \u0445\u043e\u043b\u043e\u0434\u043d\u044b\u0445 \u043e\u0442\u0442\u0435\u043d\u043a\u0430\u0445. \u0421\u043e\u0447\u0435\u0442\u0430\u043d\u0438\u0435 \u0440\u0430\u0437\u043b\u0438\u0447\u043d\u044b\u0445 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u043e\u0432 \u0432 \u043e\u0442\u0434\u0435\u043b\u043a\u0435 - \u043e\u0431\u043b\u0438\u0446\u043e\u0432\u043a\u0430 \u0441\u0442\u0435\u043d \u043d\u0430\u0442\u0443\u0440\u0430\u043b\u044c\u043d\u044b\u043c \u043a\u0438\u0440\u043f\u0438\u0447\u043e\u043c, \u0434\u0435\u0440\u0435\u0432\u044f\u043d\u043d\u044b\u043c\u0438 \u0431\u0430\u043b\u043a\u0430\u043c\u0438, \u043f\u0430\u043d\u0435\u043b\u044f\u043c\u0438, \u043f\u043e\u043a\u0440\u044b\u0442\u0438\u0435 \u043f\u043e\u043b\u043e\u0432 \u0433\u0440\u0443\u0431\u043e